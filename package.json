{
  "name": "breathingappinit",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "test": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --test src/lib/heartRate/measurementTimer.test.mjs src/lib/heartRate/heartRateManager.test.mjs src/lib/heartRate/signalProcessing.test.mjs src/lib/heartRate/sessionPayload.test.mjs src/services/supabase/authIdentitySync.test.mjs src/services/subscriptions/revenueCatClientCore.test.mjs",
    "supabase:types": "npx supabase gen types typescript --linked --schema public > src/services/supabase/database.types.ts",
    "supabase:types:local": "npx supabase gen types typescript --local --schema public > src/services/supabase/database.types.ts",
    "supabase:types:project": "sh -c 'test -n \"$SUPABASE_PROJECT_REF\" || (echo \"Set SUPABASE_PROJECT_REF first\" && exit 1); npx supabase gen types typescript --project-id \"$SUPABASE_PROJECT_REF\" --schema public > src/services/supabase/database.types.ts'",
    "web": "expo start --web"
  },
  "dependencies": {
    "@babel/plugin-proposal-nullish-coalescing-operator": "^7.18.6",
    "@babel/plugin-proposal-optional-chaining": "^7.21.0",
    "@babel/plugin-transform-template-literals": "^7.27.1",
    "@expo-google-fonts/baloo-2": "^0.4.2",
    "@expo-google-fonts/fredoka": "^0.4.1",
    "@expo-google-fonts/manrope": "^0.4.2",
    "@expo-google-fonts/nunito": "^0.4.2",
    "@expo-google-fonts/sniglet": "^0.4.1",
    "@expo-google-fonts/unbounded": "^0.4.1",
    "@expo/ngrok": "^4.1.3",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "@shopify/react-native-skia": "^2.6.2",
    "@supabase/supabase-js": "^2.104.1",
    "@tanstack/react-query": "^5.100.5",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.33",
    "expo-apple-authentication": "^55.0.13",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-constants": "^55.0.15",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image-manipulator": "~14.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "lottie-react-native": "~7.3.1",
    "posthog-react-native": "^4.43.1",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-purchases": "^10.0.1",
    "react-native-reanimated": "^4.3.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-ui": "^1.0.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-vision-camera": "^4.7.3",
    "react-native-worklets-core": "^1.6.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
