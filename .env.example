# Local development only. EAS builds use the explicitly selected environment
# and profile values in eas.json; do not copy production values into this file.
ANALYTICS_ENV=development
POSTHOG_PROJECT_TOKEN=your_development_posthog_project_token
POSTHOG_HOST=https://us.i.posthog.com

# Public mobile SDK configuration. These values are bundled into the app.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_your_public_ios_sdk_key
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your_key
EXPO_PUBLIC_APPSFLYER_DEV_KEY=your_appsflyer_dev_key
EXPO_PUBLIC_APPSFLYER_APP_ID=id1234567890

# Optional local visual overrides. Never set these in preview or production.
# EXPO_PUBLIC_FORCE_GLASS_MODE=solid
# EXPO_PUBLIC_FORCE_GLASS_FALLBACK=true

# Dashboard-only values such as META_APP_SECRET must never be added to Expo,
# EAS, EXPO_PUBLIC_* variables, or app.config.js because app config is bundled.
